; example.test zone for the AttoDNS demo
;
; This is a standard RFC 1035 master file that the demo's
; FileDnsAuthority parses on startup. Edit it through the
; demo's zone-editor UI or by hand; the demo reloads it on
; the next request after a save.
;
$ORIGIN example.test.
$TTL 3600
@       IN  SOA   ns1.example.test. admin.example.test. (
                  2026010101  ; serial: bump on every change
                  3600        ; refresh
                  1800        ; retry
                  604800      ; expire (one week)
                  86400 )     ; minimum / negative-cache TTL
@           IN  NS    ns1.example.test.
@           IN  NS    ns2.example.test.
@           IN  MX    10 mail.example.test.
@           IN  A     192.0.2.1
@           IN  AAAA  2001:db8::1
@           IN  TXT   "v=spf1 -all"
www         IN  A     192.0.2.2
www         IN  AAAA  2001:db8::2
mail        IN  A     192.0.2.3
ns1         IN  A     192.0.2.10
ns2         IN  A     192.0.2.11
ipv6only    IN  AAAA  2001:db8::42
ftp         IN  CNAME www.example.test.
*.wild      IN  A     192.0.2.99
