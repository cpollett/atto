[req]
default_bits       = 4096
default_md         = sha256
distinguished_name = dn
req_extensions     = v3_req
x509_extensions    = v3_ca
prompt             = no

[dn]
C  = US
ST = CA
L  = San Jose
O  = Seekquarry
OU = Atto Server
CN = localhost

[v3_req]
subjectAltName = @alt_names

[v3_ca]
subjectAltName = @alt_names
basicConstraints = critical, CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = localhost
IP.1  = 127.0.0.1
IP.2  = ::1
